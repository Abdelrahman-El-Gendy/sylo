*.jks
*.keystore
key.properties

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- IDE (Android Studio / IntelliJ) ---
/.idea/

# --- Claude Code project config (skills, local session state) ---
/.claude/
