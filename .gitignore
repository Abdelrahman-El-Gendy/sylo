# --- Gradle / Kotlin build output ---
*.iml
.gradle
.kotlin
**/build/
/captures
.externalNativeBuild
.cxx
*.hprof

# --- Local machine config (never shared, may contain machine-specific paths) ---
/local.properties

# --- Signing / secrets (never commit release-signing material) ---
*.jks
*.keystore
key.properties

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- IDE (Android Studio / IntelliJ) ---
# Most of .idea is shared project config; only the noisy, per-machine,
# or third-party-plugin state below is excluded.
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
/.idea/deploymentTargetSelector.xml
/.idea/deviceManager.xml
# Firebender's local AI chat history — not project config, churns every session.
/.idea/firebender/
